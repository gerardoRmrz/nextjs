{
  "name": "blog-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dropTables": "tsx ./utils/dropTables.ts",
    "deleteHistory": "npx drizzle-kit drop",
    "generateMigration": "npx drizzle-kit generate",
    "migrateSchema": "npx drizzle-kit migrate",
    "fillUsersTable": "tsx ./utils/fillUsersTable.ts",
    "fillBlogsTable": "tsx ./utils/fillBlogsTable.ts",
    "fillAllTables": "npm run dropTables && npm run generateMigration && npm run migrateSchema && npm run fillUsersTable && npm run fillBlogsTable"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@neondatabase/serverless": "^1.1.0",
    "@next/mdx": "^16.2.10",
    "@types/mdx": "^2.0.14",
    "approve-builds": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/markdown": "^8.0.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
